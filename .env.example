# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=nik_app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_must_be_at_least_32_chars_long!!
JWT_ISSUER=nik.app
JWT_AUDIENCE=nik.app
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ── Frontend port (optional, default 80) ─────────────────────────────────────
FRONTEND_PORT=80
