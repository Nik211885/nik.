# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=nik_app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_must_be_at_least_32_chars_long!!
JWT_ISSUER=nik.app
JWT_AUDIENCE=nik.app
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ── CORS ─────────────────────────────────────────────────────────────────────
# Danh sách domain được phép gọi API, cách nhau bằng dấu ;
CORS_ORIGINS=https://yourdomain.com;https://www.yourdomain.com

# ── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_URL_UPLOAD=https://api.cloudinary.com/v1_1
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_FOLDER=static

# ── Frontend port (optional, default 80) ─────────────────────────────────────
FRONTEND_PORT=80

# ── Monitoring (optional, default: admin) ────────────────────────────────────
GRAFANA_PASSWORD=change_me
